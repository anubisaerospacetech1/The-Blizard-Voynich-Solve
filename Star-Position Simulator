def calculate_star_shift(current_year=2026, target_year=1420):
    print("=" * 60)
    print(" ARCHAEOASTRONOMY: CELESTIAL POSITION REWIND ")
    print("=" * 60 + "\n")

    # The rate of precession is roughly 1 degree every 72 years
    years_passed = current_year - target_year
    degrees_shifted = years_passed / 72

    print(f"YEARS TO REWIND: {years_passed}")
    print(f"TOTAL CELESTIAL SHIFT: {degrees_shifted:.2f} degrees\n")

    # Let's test a star in the Zodiac
    # If a star is at 10 degrees in Aries today, where was it in 1420?
    current_pos = 10.0
    ancient_pos = current_pos - degrees_shifted

    print(f"Star Position (2026): {current_pos} degrees")
    print(f"Star Position (1420): {ancient_pos:.2f} degrees")
    
    print("\n[MATHEMATICAL DEDUCTION]:")
    print("If the Voynich diagram shows this star at roughly 1.6 degrees,")
    print("it is a 100% accurate match for the early 15th century.")
    print("=" * 60)

if __name__ == "__main__":
    calculate_star_shift()

